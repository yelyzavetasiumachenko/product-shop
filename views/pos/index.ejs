  // 1. Відкриття вікна оплати (БЕЗВІДМОВНИЙ ВАРІАНТ)
  // 1. Відкриття вікна оплати
  function openPaymentModal() {
    if (cart.length === 0) return;

    // Рахуємо загальну суму чека
    let totalAmount = 0;
    cart.forEach((item) => {
      totalAmount += parseFloat(item.price) * parseFloat(item.quantity);
    });

    // 1.1 Встановлюємо суму в правильний ID
    document.getElementById("modal-total-display").innerText =
      totalAmount.toFixed(2);

    // 1.2 Налаштовуємо блок бонусів
    const bonusBlock = document.getElementById("modal-bonus-block");
    const maxBonusesSpan = document.getElementById("modal-max-bonuses");
    const bonusInput = document.getElementById("bonus-spend-input");

    // Якщо клієнт є і в нього є бонуси
    if (
      currentCustomer &&
      currentCustomer.LoyaltyCard &&
      parseFloat(currentCustomer.LoyaltyCard.bonus_balance) > 0
    ) {
      bonusBlock.style.display = "block";
      const availableBonuses = parseFloat(
        currentCustomer.LoyaltyCard.bonus_balance,
      );

      // Клієнт не може списати більше, ніж сума чека
      const maxToSpend = Math.min(availableBonuses, totalAmount);

      maxBonusesSpan.innerText = availableBonuses.toFixed(2);
      bonusInput.value = 0; // За замовчуванням нічого не списуємо
      bonusInput.max = maxToSpend;
    } else {
      bonusBlock.style.display = "none";
      bonusInput.value = 0;
    }

    // 1.3 Скидаємо калькулятор готівки
    document.getElementById("pay-card").checked = true; // За замовчуванням Картка
    document.getElementById("cash-calculator").style.display = "none";
    document.getElementById("cash-received").value = "";
    document.getElementById("cash-change").innerText = "0.00 ₴";

    document.getElementById("confirm-payment-btn").disabled = false;

    // Показуємо вікно
    const modalElement = document.getElementById("paymentModal");
    const paymentModal =
      bootstrap.Modal.getInstance(modalElement) ||
      new bootstrap.Modal(modalElement);
    paymentModal.show();
  }

  function validateBonusSpend() {
    const input = document.getElementById("bonus-spend-input");
    const maxVal = parseFloat(input.max) || 0;

    // Читаємо значення, але НЕ перезаписуємо його одразу
    let spendVal = parseFloat(input.value);
    if (isNaN(spendVal)) spendVal = 0; // Якщо поле порожнє, рахуємо як 0

    // Перезаписуємо поле ТІЛЬКИ якщо є порушення лімітів
    if (spendVal > maxVal) {
      input.value = maxVal;
      spendVal = maxVal;
    } else if (spendVal < 0) {
      input.value = 0;
      spendVal = 0;
    }
    // Якщо число в межах норми (наприклад, "210.") — ми його не чіпаємо,
    // дозволяючи касиру спокійно дописати копійки після крапки!

    // Перераховуємо суму "До сплати" з урахуванням знижки
    let totalAmount = 0;
    cart.forEach((item) => (totalAmount += item.price * item.quantity));

    const finalTotal = totalAmount - spendVal;
    document.getElementById("modal-total-display").innerText =
      finalTotal.toFixed(2);

    calculateChange(); // Оновлюємо решту, якщо відкрито калькулятор готівки
  }

  // 3. Калькулятор решти
  function calculateChange() {
    const received =
      parseFloat(document.getElementById("cash-received").value) || 0;
    const finalTotal =
      parseFloat(document.getElementById("modal-total-display").innerText) || 0;
    const changeEl = document.getElementById("cash-change");

    const change = received - finalTotal;

    if (change >= 0) {
      changeEl.innerText = change.toFixed(2) + " ₴";
      changeEl.className = "fs-3 fw-bold text-success";
    } else {
      changeEl.innerText = "0.00 ₴";
      changeEl.className = "fs-3 fw-bold text-danger";
    }
  }

  // 4. Логіка перемикання Картка/Готівка (показує калькулятор)
  document.querySelectorAll('input[name="paymentMethod"]').forEach((radio) => {
    radio.addEventListener("change", function () {
      const cashCalc = document.getElementById("cash-calculator");
      cashCalc.style.display = this.value === "Cash" ? "block" : "none";
    });
  });

  // 5. Фінальна відправка чека на сервер
  async function submitCheckout() {
    // Читаємо обраний спосіб оплати з радіокнопки
    const paymentMethod = document.querySelector(
      'input[name="paymentMethod"]:checked',
    ).value;
    const bonusesSpent =
      parseFloat(document.getElementById("bonus-spend-input").value) || 0;

    try {
      const payload = {
        items: cart,
        payment_method: paymentMethod,
        // Відправляємо саме ID клієнта, як і очікує сервер
        customer_id: currentCustomer ? currentCustomer.id : null,
        // Змінили назву змінної на ту, яку чекає сервер (без "es")
        bonus_spent: bonusesSpent,
        shift_id: localStorage.getItem("shift_id"),
      };

      const response = await axios.post("/api/pos/checkout", payload);

      if (response.data.success) {
        // Ховаємо модалку
        const modalEl = document.getElementById("paymentModal");
        const modalInstance = bootstrap.Modal.getInstance(modalEl);
        if (modalInstance) modalInstance.hide();

        Swal.fire({
          icon: "success",
          title: "Чек оплачено!",
          text: `Фіскальний номер: ${response.data.fiscal_number}`,
          confirmButtonColor: "#198754",
        });

        // Очищаємо касу
        cart = [];
        clearCustomerInput();
        renderCart();
        incrementReceiptNumber();
        document.getElementById("barcode-input").focus();
      }
    } catch (error) {
      Swal.fire({
        icon: "error",
        title: "Помилка",
        text: "Не вдалося провести оплату.",
      });
    }
  }

  // --- ЖИВИЙ ПОШУК ЗА НАЗВОЮ ---
  let searchTimeout = null;

  async function handleSearchInput(query) {
    const dropdown = document.getElementById("search-results-dropdown");

    // Якщо введено менше 2 символів — ховаємо список
    if (query.trim().length < 2) {
      dropdown.style.display = "none";
      return;
    }

    // Використовуємо debounce (затримку), щоб не спамити сервер запитами на кожну літеру
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(async () => {
      try {
        const response = await axios.get(
          `/api/products/search?q=${encodeURIComponent(query)}`,
        );
        if (response.data.success && response.data.products.length > 0) {
          renderSearchResults(response.data.products);
        } else {
          // ВЛАСНЕ ПОВІДОМЛЕННЯ ПРЯМО У ВИПАДАЮЧОМУ СПИСКУ
          dropdown.innerHTML = `
                    <li class="list-group-item text-muted text-center py-3 bg-light">
                        <i class="bi bi-search fs-4 d-block mb-1"></i>
                        Товар не знайдено
                    </li>`;
          dropdown.style.display = "block";
        }
      } catch (error) {
        console.error("Помилка живого пошуку:", error);
      }
    }, 300); // Чекаємо 300 мілісекунд після того, як касир перестав друкувати
  }

  function clearSearchInput() {
    const input = document.getElementById("barcode-input");
    input.value = ""; // Стираємо текст
    document.getElementById("search-results-dropdown").style.display = "none"; // Ховаємо список
    input.focus(); // Повертаємо курсор назад, щоб касир міг одразу сканувати далі
  }

  function renderSearchResults(products) {
    const dropdown = document.getElementById("search-results-dropdown");
    dropdown.innerHTML = ""; // Очищаємо старі результати

    products.forEach((prod) => {
      const li = document.createElement("li");
      li.className =
        "list-group-item list-group-item-action d-flex justify-content-between align-items-center";
      li.style.cursor = "pointer";
      // Малюємо рядок товару
      li.innerHTML = `
            <div>
                <span class="fw-bold text-dark">${prod.name}</span><br>
                <small class="text-muted"><i class="bi bi-upc"></i> ${prod.barcode} | Залишок: <span class="fw-bold">${prod.available_stock}</span> ${getUomUa(prod.uom)}</small>
            </div>
            <span class="badge bg-success rounded-pill fs-6">${prod.price.toFixed(2)} ₴</span>
        `;

      // Клік по товару зі списку додає його в кошик
      li.onclick = () => {
        addProductToCart(prod);
        document.getElementById("barcode-input").value = "";
        dropdown.style.display = "none";
        document.getElementById("barcode-input").focus();
      };

      dropdown.appendChild(li);
    });

    dropdown.style.display = "block"; // Показуємо список
  }

  // Приховуємо список, якщо касир клікнув десь в іншому місці екрана
  document.addEventListener("click", (e) => {
    if (
      !e.target.closest("#barcode-form") &&
      !e.target.closest("#search-results-dropdown")
    ) {
      document.getElementById("search-results-dropdown").style.display = "none";
    }
  });

  // Очищення поточного чека
  function confirmClearCart() {
    if (cart.length === 0 && !currentCustomer) return; // Якщо каса і так порожня, нічого не робимо

    Swal.fire({
      title: "Скасувати чек?",
      text: "Усі відскановані товари та дані клієнта будуть видалені з екрана.",
      icon: "warning",
      showCancelButton: true,
      confirmButtonColor: "#d33",
      cancelButtonColor: "#6c757d",
      confirmButtonText: "Так, скасувати",
      cancelButtonText: "Повернутися",
    }).then((result) => {
      if (result.isConfirmed) {
        cart = []; // Очищаємо масив товарів
        clearCustomerInput(); // Очищаємо обраного клієнта
        renderCart(); // Перемальовуємо порожній список
        document.getElementById("barcode-input").focus(); // Повертаємо курсор на сканер
      }
    });
  }

  // Функція закриття зміни з фінальним Z-звітом
  async function logoutCashier() {
    const shiftId = localStorage.getItem("shift_id");
    if (!shiftId) {
      window.location.href = "/logout"; // Оновлено
      return;
    }

    try {
      const response = await axios.get(`/api/auth/shift-summary/${shiftId}`);
      if (!response.data.success) throw new Error("Не вдалося отримати звіт");

      const data = response.data.summary;

      Swal.fire({
        title: "🔒 Фінальний Z-звіт",
        html: `
          <table class="table table-bordered text-start align-middle fs-6">
            <tbody>
              <tr>
                <td class="fw-bold bg-light">Кількість чеків:</td>
                <td class="text-end fw-bold text-dark">${data.sales_count}</td>
              </tr>
              <tr>
                <td class="text-muted">Розмінна готівка (ранок):</td>
                <td class="text-end">${data.starting_cash} ₴</td>
              </tr>
              <tr>
                <td class="text-success fw-bold">Виручка ГОТІВКА (+):</td>
                <td class="text-end text-success fw-bold">+${data.cash_sales} ₴</td>
              </tr>
              <tr>
                <td class="text-primary fw-bold">Виручка КАРТКА:</td>
                <td class="text-end text-primary fw-bold">${data.card_sales} ₴</td>
              </tr>
              <tr class="table-warning">
                <td class="text-warning-emphasis">Списано бонусами (Points):</td>
                <td class="text-end">-${data.bonuses_spent} ₴</td>
              </tr>
              <tr>
                <td class="text-muted">Нараховано бонусів клієнтам:</td>
                <td class="text-end text-muted">+${data.bonuses_earned} ₴</td>
              </tr>
              <tr class="table-success fs-5">
                <td class="fw-bold text-success">МАЄ БУТИ В КАСІ:</td>
                <td class="text-end fw-bold text-success">${data.expected_cash} ₴</td>
              </tr>
            </tbody>
          </table>
          <p class="text-danger small fw-bold mt-2 mb-0">⚠️ Увага! Після натискання зміну буде закрито остаточно.</p>
        `,
        showCancelButton: true,
        confirmButtonColor: "#198754",
        cancelButtonColor: "#6c757d",
        confirmButtonText:
          '<i class="bi bi-cash-register"></i> Здати касу та вийти',
        cancelButtonText: "Скасувати",
        width: "450px",
      }).then(async (result) => {
        if (result.isConfirmed) {
          const closeResponse = await axios.post("/api/auth/close-shift", {
            shift_id: shiftId,
          });

          if (closeResponse.data.success) {
            localStorage.removeItem("shift_id");
            localStorage.removeItem("cashier_name");
            localStorage.removeItem("pos_locked");

            Swal.fire({
              icon: "success",
              title: "Зміну закрито!",
              text: "Каса успішно здана. Гарного вечора!",
              confirmButtonColor: "#198754",
            }).then(() => {
              // ВАЖЛИВА ЗМІНА: Викликаємо маршрут знищення сесії
              window.location.href = "/logout";
            });
          }
        }
      });
    } catch (error) {
      console.error(error);
      Swal.fire({
        icon: "error",
        title: "Помилка",
        text: "Не вдалося згенерувати фінансовий звіт для закриття каси.",
      });
    }
  }

  // Перехід у режим перерви (тут усе чудово, нічого міняти не треба)
  function goOnBreak() {
    localStorage.setItem("pos_locked", "true");
    window.location.href = "/pos/lock";
  }

  // Функція для візуального оновлення номера чека
  function incrementReceiptNumber() {
    const receiptSpan = document.getElementById("current-receipt-number");
    if (!receiptSpan) return;

    // Беремо поточний текст (наприклад, "#00002"), відкидаємо "#" і перетворюємо на число
    let currentNumber = parseInt(receiptSpan.innerText.replace("#", ""), 10);

    // Додаємо 1 для наступного чека
    let nextNumber = currentNumber + 1;

    // Перетворюємо назад у рядок і форматуємо (додаємо нулі спереду, щоб було 5 символів)
    let formattedNumber = "#" + String(nextNumber).padStart(5, "0");

    // Оновлюємо цифру на екрані
    receiptSpan.innerText = formattedNumber;
  }
  // ------------------------------
</script>

