<!DOCTYPE html>
<html lang="uk">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Retail ERP System</title>
    <link
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css"
    />
    <style>
      /* Базові стилі системи */
      body {
        background-color: #f8f9fa;
      }
      .pos-container {
        height: 100vh;
        overflow: hidden;
      }
    </style>
  </head>
  <body>
    <nav class="navbar navbar-expand-lg navbar-dark bg-dark">
      <div class="container-fluid">
        <a class="navbar-brand" href="/">ERP Market</a>
        <div class="d-flex text-white">
          <span class="me-3"
            ><i class="bi bi-person-circle"></i> Користувач:
            <span id="cashier-name-display" class="fw-bold text-white"></span
          ></span>
          <!-- <a href="/logout" class="btn btn-sm btn-outline-light">Вийти</a> -->
          <button
            class="btn btn-outline-warning btn-sm fw-bold me-2"
            onclick="goOnBreak()"
          >
            <i class="bi bi-pause-fill"></i> Перерва
          </button>
          <button
            class="btn btn-outline-light btn-sm fw-bold"
            onclick="logoutCashier()"
          >
            <i class="bi bi-box-arrow-right"></i> Вийти
          </button>
        </div>
      </div>
    </nav>
  </body>
</html>
