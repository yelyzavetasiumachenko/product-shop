<%- include('../partials/header') %>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Управління складом</h2>
        <button class="btn btn-primary"><i class="bi bi-box-seam"></i> Прийняти нову партію</button>
    </div>

    <ul class="nav nav-tabs mb-4">
        <li class="nav-item"><a class="nav-link active" href="#">Залишки (Партії)</a></li>
        <li class="nav-item"><a class="nav-link" href="#">Замовлення (PO)</a></li>
        <li class="nav-item"><a class="nav-link" href="#">Логи інвентаризації</a></li>
    </ul>

    <div class="table-responsive bg-white shadow-sm rounded p-3">
        <table class="table table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Артикул</th>
                    <th>Назва товару</th>
                    <th>Залишок</th>
                    <th>Постачальник</th>
                    <th>Термін придатності</th>
                    <th>Статус</th>
                </tr>
            </thead>
            <tbody>
                <% batches.forEach(function(batch) { 
                    // Логіка підсвітки (якщо до кінця терміну < 3 днів)
                    let today = new Date();
                    let expiry = new Date(batch.expiry_date);
                    let diffDays = Math.ceil((expiry - today) / (1000 * 60 * 60 * 24));
                    let rowClass = (diffDays <= 3 && batch.status === 'Active') ? 'table-danger' : '';
                %>
                <tr class="<%= rowClass %>">
                    <td><%= batch.Product.sku %></td>
                    <td class="fw-bold"><%= batch.Product.name %></td>
                    <td><%= batch.quantity %> <%= batch.Product.uom %></td>
                    <td><%= batch.Supplier.name %></td>
                    <td>
                        <%= expiry.toLocaleDateString('uk-UA') %>
                        <% if (diffDays <= 3) { %>
                            <span class="badge bg-danger ms-2">Спливає!</span>
                        <% } %>
                    </td>
                    <td>
                        <span class="badge bg-<%= batch.status === 'Active' ? 'success' : 'warning' %>">
                            <%= batch.status %>
                        </span>
                    </td>
                </tr>
                <% }); %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../partials/footer') %>