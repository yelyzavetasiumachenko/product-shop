<%- include('partials/header') %>
<%- include('partials/sidebar') %>

<div class="main-content">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="fw-bold text-dark">Контроль кас та персоналу</h2>
    </div>

    <div class="card border-0 shadow-sm">
        <div class="card-body p-4">
            <h5 class="fw-bold mb-4">Історія касових змін (Z-звіти)</h5>
            
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Касир</th>
                            <th>Початок зміни</th>
                            <th>Кінець зміни</th>
                            <th>Розмінна монета</th>
                            <th>Здано готівки (Z-звіт)</th>
                            <th>Статус</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% shifts.forEach(function(shift) { %>
                            <tr>
                                <td class="fw-bold text-primary">
                                    <i class="bi bi-person-badge me-2"></i><%= shift.cashier_name %>
                                </td>
                                
                                <td><%= new Date(shift.start_time).toLocaleString('uk-UA') %></td>
                                
                                <td>
                                    <%= shift.end_time ? new Date(shift.end_time).toLocaleString('uk-UA') : '—' %>
                                </td>
                                
                                <td><%= parseFloat(shift.starting_cash).toFixed(2) %> ₴</td>
                                
                                <td class="fw-bold <%= shift.expected_cash ? 'text-success' : 'text-muted' %>">
                                    <%= shift.expected_cash ? parseFloat(shift.expected_cash).toFixed(2) + ' ₴' : '—' %>
                                </td>
                                
                                <td>
                                    <% if (shift.end_time) { %>
                                        <span class="badge bg-secondary">Закрита</span>
                                    <% } else { %>
                                        <span class="badge bg-success shadow-sm">Відкрита</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }); %>
                        
                        <% if (shifts.length === 0) { %>
                            <tr>
                                <td colspan="6" class="text-center text-muted py-4">Жодної зміни не знайдено</td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>

        </div>
    </div>
</div>

<%- include('partials/footer') %>