  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="fw-bold text-dark">Статистика магазину</h2>
    <div class="text-muted">
      <i class="bi bi-calendar3"></i> <span id="current-date"></span>
    </div>
  </div>

  <div class="d-flex justify-content-between align-items-center mb-3">
    <h5 class="mb-0 text-secondary fw-bold">Метрики за день</h5>
    <div
      class="d-flex align-items-center bg-white p-2 rounded shadow-sm border"
    >
      <label class="text-muted small me-2 mb-0 fw-bold">Дата:</label>
      <input
        type="date"
        id="filter-single-date"
        class="form-control form-control-sm border-0 me-2"
        style="background: #f8f9fa"
      />

      <button
        class="btn btn-sm btn-primary fw-bold"
        onclick="updateDailyStats()"
      >
        <i class="bi bi-arrow-clockwise"></i>
      </button>
    </div>
  </div>

