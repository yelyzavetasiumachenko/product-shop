<%- include('partials/header') %> <%- include('partials/sidebar') %>
<div class="d-flex w-100">

    <div class="main-content flex-grow-1 p-4 bg-light w-100">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2 class="fw-bold text-dark">Клієнти та програма лояльності</h2>
            <!-- <button class="btn btn-primary shadow-sm" data-bs-toggle="modal" data-bs-target="#addClientModal">
                <i class="bi bi-person-plus me-2"></i>Додати клієнта
            </button> -->
        </div>

        <div class="card shadow-sm border-0 mb-4">
            <div class="card-body">
                <div class="input-group">
                    <span class="input-group-text bg-white border-end-0"><i class="bi bi-search text-muted"></i></span>
                    <input type="text" id="searchClient" class="form-control border-start-0" placeholder="Пошук за ім'ям, телефоном або номером карти...">
                </div>
            </div>
        </div>

        <div class="card shadow-sm border-0">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>Ім'я клієнта</th>
                                <th>Телефон</th>
                                <th>Картка лояльності</th>
                                <th>Бонуси</th>
                                <th>Дата реєстрації</th>
                                <th class="text-end">Дії</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (!clients || clients.length === 0) { %>
                                <tr><td colspan="6" class="text-center text-muted py-4">Жодного клієнта не знайдено</td></tr>
                            <% } else { %>
                                <% clients.forEach(function(client) { %>
                                    <tr>
                                        <td class="fw-bold">
                                            <i class="bi bi-person-circle text-secondary me-2"></i>
                                            <%= client.name || 'Невідомо' %>
                                        </td>
                                        
                                        <td class="small">
                                            <div><i class="bi bi-telephone text-muted me-1"></i> <%= client.phone || '—' %></div>
                                        </td>
                                        
                                        <td>
                                            <% if (client.barcode) { %>
                                                <span class="badge <%= client.card_status === 'Blocked' ? 'bg-danger' : 'bg-light text-dark border' %>">
                                                    <i class="bi bi-upc-scan me-1"></i><%= client.barcode %>
                                                </span>
                                                <% if (client.card_status === 'Blocked') { %>
                                                    <div class="small text-danger mt-1" style="font-size: 0.75rem;"><i class="bi bi-lock-fill"></i> Заблокована</div>
                                                <% } %>
                                            <% } else { %>
                                                <span class="text-muted small">Немає картки</span>
                                            <% } %>
                                        </td>
                                        
                                        <td class="fw-bold <%= parseFloat(client.points) > 0 ? 'text-success' : 'text-muted' %>">
                                            <%= parseFloat(client.points).toFixed(2) %>
                                        </td>
                                        
                                        <td class="text-muted small">
                                            <%= client.registration_date ? new Date(client.registration_date).toLocaleDateString('uk-UA') : '—' %>
                                        </td>
                                        
                   <td class="text-end">
    <div class="btn-group shadow-sm">
        <button class="btn btn-sm btn-outline-secondary" 
                onclick="openEditModal('<%= client.id %>', '<%= client.first_name %>', '<%= client.last_name %>', '<%= client.phone %>', '<%= client.barcode || '-' %>')" 
                title="Редагувати">
            <i class="bi bi-pencil"></i>
        </button>

        <% if (client.barcode) { %>
            <button class="btn btn-sm <%= client.card_status === 'Blocked' ? 'btn-success' : 'btn-outline-warning' %>" 
                    onclick="toggleCardStatus('<%= client.id %>', '<%= client.card_status %>')" 
                    title="<%= client.card_status === 'Blocked' ? 'Розблокувати' : 'Заблокувати' %>">
                <i class="bi <%= client.card_status === 'Blocked' ? 'bi-unlock' : 'bi-lock' %>"></i>
            </button>
        <% } %>

        <button class="btn btn-sm btn-outline-danger" 
                onclick="deleteClient('<%= client.id %>')" 
                title="Видалити">
            <i class="bi bi-trash"></i>
        </button>
    </div>
</td>
                                    </tr>
                                <% }); %>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="editClientModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-primary border-bottom-0">
                <h5 class="modal-title fw-bold text-white">Редагувати клієнта</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <form id="editClientForm">
                    <input type="hidden" id="edit_client_id" name="id">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label large mb-1 fw-bold">Ім'я <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="edit_first_name" name="first_name" required>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label large fw-bold mb-1">Прізвище <span class="text-danger">*</span></label>
                            <input type="text" class="form-control" id="edit_last_name" name="last_name" required>
                        </div>
                        <div class="col-12">
                            <label class="form-label large fw-bold mb-1">Номер телефону <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light">+380</span>
                                <input type="text" class="form-control" id="edit_phone" name="phone" maxlength="9" pattern="\d{9}" placeholder="501234567" required>
                            </div>
                        </div>
                        <div class="col-12">
                            <label class="form-label large fw-bold mb-1">Картка лояльності <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light"><i class="bi bi-upc-scan"></i></span>
                                <input type="text" class="form-control" id="edit_barcode" name="barcode" placeholder="Немає картки">
                            </div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer border-top-0 bg-light">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Скасувати</button>
                <button type="submit" form="editClientForm" class="btn btn-primary">Зберегти зміни</button>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="confirmActionModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow">
            <div class="modal-body text-center p-4">
                <i class="bi bi-exclamation-circle text-warning mb-3" style="font-size: 3rem;"></i>
                <h5 class="fw-bold mb-3" id="confirmTitle">Підтвердження</h5>
                <p class="text-muted mb-4" id="confirmMessage">Ви впевнені?</p>
                <div class="d-flex justify-content-center gap-2">
                    <button type="button" class="btn btn-light" data-bs-dismiss="modal">Скасувати</button>
                    <button type="button" class="btn btn-primary" id="confirmBtn">Так, продовжити</button>
                </div>
            </div>
        </div>
    </div>
</div>
