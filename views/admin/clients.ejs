<%- include('partials/footer') %>
<script>
    document.addEventListener("DOMContentLoaded", function () {
        // 1. ЖИВИЙ ПОШУК
        const searchInput = document.getElementById("searchClient");
        const tableRows = document.querySelectorAll("tbody tr");

        searchInput.addEventListener("input", function (e) {
            const term = e.target.value.toLowerCase().trim();

            tableRows.forEach(row => {
                // Пропускаємо рядок "Жодного клієнта не знайдено", якщо він є
                if (row.querySelector("td[colspan]")) return;

                // Беремо весь текст з рядка (ім'я, телефон, штрихкод)
                const rowText = row.textContent.toLowerCase();
                
                // Якщо текст знайдено — показуємо рядок, якщо ні — ховаємо
                if (rowText.includes(term)) {
                    row.style.display = "";
                } else {
                    row.style.display = "none";
                }
            });
        });
    });

    let confirmCallback = null;

    // Функція для красивого вікна підтвердження
    function showConfirm(title, message, btnClass, btnText, callback) {
        document.getElementById('confirmTitle').innerText = title;
        document.getElementById('confirmMessage').innerText = message;
        
        const confirmBtn = document.getElementById('confirmBtn');
        confirmBtn.className = `btn ${btnClass}`;
        confirmBtn.innerText = btnText;
        
        confirmCallback = callback;
        new bootstrap.Modal(document.getElementById('confirmActionModal')).show();
    }

    // Виклик при кліку на кнопку в вікні підтвердження
    document.getElementById('confirmBtn').addEventListener('click', () => {
        if (confirmCallback) confirmCallback();
        bootstrap.Modal.getInstance(document.getElementById('confirmActionModal')).hide();
    });

    // 1. Відкриття вікна редагування
    function openEditModal(id, firstName, lastName, phone, barcode) {
        document.getElementById('edit_client_id').value = id;
        document.getElementById('edit_first_name').value = firstName;
        document.getElementById('edit_last_name').value = lastName;
        document.getElementById('edit_barcode').value = barcode;
        
        let cleanPhone = phone.startsWith('+380') ? phone.slice(4) : phone;
        document.getElementById('edit_phone').value = cleanPhone;

        new bootstrap.Modal(document.getElementById('editClientModal')).show();
    }

    // 2. Збереження відредагованого клієнта
    document.getElementById("editClientForm").addEventListener("submit", async function(e) {
        e.preventDefault();
        const data = Object.fromEntries(new FormData(e.target).entries());
        
        try {
            const res = await fetch('/admin/clients/edit', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(data)
            });
            if (res.ok) location.reload();
        } catch (err) { console.error(err); }
    });

    // 3. Блокування / Розблокування
    function toggleCardStatus(clientId, currentStatus) {
        const newStatus = currentStatus === 'Blocked' ? 'Active' : 'Blocked';
        const actionName = newStatus === 'Blocked' ? 'заблокувати' : 'розблокувати';
        
        showConfirm('Зміна статусу', `Ви дійсно хочете ${actionName} цю картку?`, 
                    newStatus === 'Blocked' ? 'btn-warning' : 'btn-success', 
                    newStatus === 'Blocked' ? 'Заблокувати' : 'Розблокувати', 
        async () => {
            const res = await fetch('/admin/clients/toggle-card', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ clientId, newStatus })
            });
            if (res.ok) location.reload();
        });
    }

    // 4. Видалення клієнта
    function deleteClient(clientId) {
        showConfirm('Видалення', 'Увага! Клієнта та його картку буде видалено назавжди. Продовжити?', 'btn-danger', 'Видалити', 
        async () => {
            const res = await fetch(`/admin/clients/${clientId}`, { method: 'DELETE' });
            if (res.ok) location.reload();
        });
    }
</script>